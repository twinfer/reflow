{
  "name": "reflow_starter",
  "deny_rules": [],
  "allow_rules": [
    {
      "name": "ingress_open",
      "request": {
        "paths": ["/reflow.ingress.v1.Ingress/*"]
      }
    },
    {
      "name": "ingress_rest_open",
      "request": {
        "paths": [
          "/v1/*",
          "/v1/*/*",
          "/v1/*/*/*",
          "/v1/*/*/*/*",
          "/v1/*/*/*/*/*"
        ]
      }
    },
    {
      "name": "webhooks_open",
      "request": {
        "paths": [
          "/webhooks/*",
          "/webhooks/*/*",
          "/webhooks/*/*/*"
        ]
      }
    },
    {
      "name": "delivery_node",
      "request": {
        "paths": ["/reflow.delivery.v1.Delivery/*"],
        "headers": [
          { "key": "x-reflow-principal", "values": ["node/*"] }
        ]
      }
    },
    {
      "name": "clusterctl_operator",
      "request": {
        "paths": ["/reflow.clusterctl.v1.ClusterCtl/*"],
        "headers": [
          { "key": "x-reflow-principal", "values": ["operator/*"] }
        ]
      }
    },
    {
      "name": "clusterctl_node_selfjoin",
      "request": {
        "paths": ["/reflow.clusterctl.v1.ClusterCtl/SelfJoin"],
        "headers": [
          { "key": "x-reflow-principal", "values": ["node/*"] }
        ]
      }
    },
    {
      "name": "config_operator",
      "request": {
        "paths": ["/reflow.config.v1.Config/*"],
        "headers": [
          { "key": "x-reflow-principal", "values": ["operator/*"] }
        ]
      }
    }
  ]
}
