{
  "name": "reflow_starter",
  "deny_rules": [],
  "allow_rules": [
    {
      "name": "ingress_open",
      "request": {
        "paths": ["/reflow.ingress.v1.Ingress/*"]
      }
    },
    {
      "name": "ingress_rest_open",
      "request": {
        "paths": [
          "/v1/*",
          "/v1/*/*",
          "/v1/*/*/*",
          "/v1/*/*/*/*",
          "/v1/*/*/*/*/*"
        ]
      }
    },
    {
      "name": "delivery_node",
      "request": {
        "paths": ["/reflow.delivery.v1.Delivery/*"],
        "headers": [
          { "key": "x-reflow-principal", "values": ["node/*"] }
        ]
      }
    },
    {
      "name": "admin_operator",
      "request": {
        "paths": ["/reflow.admin.v1.Admin/*"],
        "headers": [
          { "key": "x-reflow-principal", "values": ["operator/*"] }
        ]
      }
    },
    {
      "name": "admin_node_selfjoin",
      "request": {
        "paths": ["/reflow.admin.v1.Admin/SelfJoin"],
        "headers": [
          { "key": "x-reflow-principal", "values": ["node/*"] }
        ]
      }
    }
  ]
}
